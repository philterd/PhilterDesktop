<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>PhilterDesktop.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Philterd.Phileas" Version="1.2.0" />
    <PackageReference Include="Xceed.Words.NET" Version="5.0.25228.6154" />
    <PackageReference Include="LiteDB" Version="5.0.21" />
  </ItemGroup>

  <!-- Untracked Xceed license key file; copied to output when present (see .gitignore). -->
  <ItemGroup>
    <None Include="xceed-license.json" Condition="Exists('xceed-license.json')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- Guard against accidentally shipping a Release/MSIX build without the Xceed
       license (which would silently run Word redaction in trial mode). It's a warning
       by default (so CI's keyless Release build still passes); set
       XceedLicenseRequired=true (e.g. when packaging the installer) to make it an error. -->
  <Target Name="CheckXceedLicense" BeforeTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <Warning Condition="!Exists('xceed-license.json') And '$(XceedLicenseRequired)' != 'true'"
             Text="xceed-license.json is missing: this Release build will use Xceed trial mode for Word redaction. Add the key file before packaging the installer (or set XceedLicenseRequired=true to fail the build)." />
    <Error Condition="!Exists('xceed-license.json') And '$(XceedLicenseRequired)' == 'true'"
           Text="xceed-license.json is missing: refusing to build Release with XceedLicenseRequired=true. Add PhilterDesktop\xceed-license.json before packaging." />
  </Target>

  <ItemGroup>
    <Compile Update="Properties\Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Properties\Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

</Project>
images/*
# The application icon is referenced by <ApplicationIcon> and must be available to the build (incl. CI).
!images/PhilterDesktop.ico
*.swp
*.*~
project.lock.json
.DS_Store
*.pyc
nupkg/

# Visual Studio Code
.vscode/*
!.vscode/settings.json

# Rider
.idea/

# Visual Studio
.vs/

# Fleet
.fleet/

# Code Rush
.cr/

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Bundled on-device PhEye model (~90 MB; downloaded at build time, not committed)
PhilterDesktop/Models/ph-eye-pii-en-xsmall/
!PhilterDesktop/Models/README.md

# Redacted output files (e.g. *_redacted-draft.*) must never be committed — they may contain PII
*_redacted*

# Redaction explanation exports (e.g. *_redaction-explanation.json) list the original, un-redacted
# text, so they are as sensitive as the source and must never be committed.
*-explanation.json

# Generated redaction reports (e.g. *_redaction-report.pdf). These contain no original text,
# but they are generated artifacts and shouldn't be committed.
*_redaction-report.*

# Visual Studio regenerates a companion .sln; the canonical solution is PhilterDesktop.slnx.
/PhilterDesktop.sln

# Installer build artifacts
Installer/Output/
# Generated offline user-guide PDF (built from docs/ markdown by build-user-guide.ps1)
Installer/dist/

# Local code-signing settings (Azure Trusted Signing account/profile) — never commit
Installer/signing.local.json
# Auto-restored signing tools (Trusted Signing dlib from NuGet)
Installer/tools/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
msbuild.log
msbuild.err
msbuild.wrn

# Node.js build artifacts
node_modules/
package-lock.json
package.json

# App screenshots (published in the philterd-website repo; generated locally on demand)
screenshots/

# Real public-domain test documents (kept local, not committed). Integration tests that use them
# skip automatically when the directory is empty/absent.
real-documents/
    </Compile>
    <Compile Update="PolicyEditor\FilterReplacementStrategies\AddIdentifierFilterStrategyForm.Designer.vb">
      <DependentUpon>AddIdentifierFilterStrategyForm.vb</DependentUpon>
    </Compile>
    <Compile Update="PolicyEditor\FilterReplacementStrategies\AddIpAddressFilterStrategyForm.Designer.vb">
      <DependentUpon>AddIpAddressFilterStrategyForm.vb</DependentUpon>

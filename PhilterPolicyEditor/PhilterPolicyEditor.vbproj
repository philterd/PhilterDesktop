      <DependentUpon>AddCreditCardFilterStrategyForm.vb</DependentUpon>
    </Compile>
    <Compile Update="PolicyEditor\FilterReplacementStrategies\AddCustomDictionaryFilterStrategyForm.Designer.vb">
